# ============================================
# CONFIGURACIÓN DEL BOT - COPIA ESTE ARCHIVO COMO .env
# ============================================

# NOTA: En este proyecto, el número se pide al iniciar el bot
# Este archivo es solo para referencia futura

# Modelo de Ollama a usar
OLLAMA_MODEL=tinyllama:1.1b-chat-q4_K_M

# Temperatura (creatividad) 0.1 - 1.0
OLLAMA_TEMPERATURE=0.7

# Máximo de tokens por respuesta
OLLAMA_MAX_TOKENS=200

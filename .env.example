# ============================================
# CONFIGURACIÓN DEL BOT
# ============================================

# Número de WhatsApp que administrará el bot
# (con código de país, sin + ni espacios)
# Ejemplo: 5215512345678
WHATSAPP_NUMBER=

# Modelo de Ollama a usar
# Recomendado: llama3.2:1b (el más ligero)
OLLAMA_MODEL=llama3.2:1b

# Temperatura (creatividad) 0.1 - 1.0
OLLAMA_TEMPERATURE=0.7

# Máximo de tokens por respuesta
OLLAMA_MAX_TOKENS=200

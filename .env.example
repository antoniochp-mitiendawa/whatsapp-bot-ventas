# ============================================
# CONFIGURACIÓN DEL BOT - COPIA ESTE ARCHIVO COMO .env
# ============================================

# GOOGLE SHEETS - URL DE LA WEB APP
# La obtienes al implementar tu Web App en Apps Script
# Debe terminar en /exec
GOOGLE_SHEETS_URL=https://script.google.com/macros/s/ABCDEFGHIJKLMNOPQRSTUVWXYZ/exec

# WHATSAPP - NÚMERO PARA VINCULAR
# Número completo con código de país, sin + ni espacios
# Ejemplo: 5215512345678 (México)
WHATSAPP_NUMBER=

# OLLAMA - CONFIGURACIÓN
OLLAMA_MODEL=llama3.2:1b
OLLAMA_TEMPERATURE=0.7
OLLAMA_MAX_TOKENS=200

# RUTA DE MULTIMEDIA EN ANDROID
# Las imágenes deben estar en esta carpeta
MULTIMEDIA_PATH=/storage/emulated/0/WhatsAppBot/

# CONFIGURACIÓN DE CACHÉ
# Horarios para actualizar datos desde Google Sheets (formato 24h)
CACHE_UPDATE_HOURS=06:00,18:00

# LOGS
LOG_LEVEL=info

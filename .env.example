# ============================================
# CONFIGURACIÓN DEL BOT - COPIA ESTE ARCHIVO COMO .env
# ============================================

# URL de Google Sheets (obtenida al implementar la Web App)
URL_SHEETS=https://script.google.com/macros/s/ABCDEFGHIJKLMNOPQRSTUVWXYZ/exec

# Número de WhatsApp para vincular (con código de país, sin + ni espacios)
# Ejemplo: 5215512345678 (México)
PAIRING_NUMBER=521234567890

# ============================================
# NOTA: Este archivo es solo una plantilla.
# Durante la instalación, se creará automáticamente
# con los datos que proporciones.
# ============================================
